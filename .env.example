# ====== Database (Neon Postgres) ======
# Connection string dari Neon (pakai pooled connection untuk serverless).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/santrikalong?sslmode=require"
# Direct (non-pooled) untuk migrasi Prisma.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/santrikalong?sslmode=require"

# ====== Storage (private blob, S3-compatible: Cloudflare R2 / S3 / Wasabi) ======
# Bucket PRIVAT. File TIDAK pernah diakses lewat domain blob — selalu via /media di domain kita.
STORAGE_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
STORAGE_REGION="auto"
STORAGE_BUCKET="santrikalong-private"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# ====== App ======
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="ganti-dengan-random-string-panjang"
# Penanda tangan bukti PDF (invoice/payout). Bila kosong, pakai AUTH_SECRET.
# Set terpisah agar rotasi sesi tidak membatalkan bukti yang sudah terbit.
DOC_SIGNING_SECRET="ganti-dengan-random-string-panjang-lain"

# ====== Payment gateways (diisi & di-toggle dari panel superadmin; ini fallback dev) ======
# Midtrans Snap. Ambil key dari dashboard Midtrans (Settings > Access Keys).
# Set webhook "Payment Notification URL" ke: <NEXT_PUBLIC_APP_URL>/api/payment/midtrans
# Untuk dev di localhost, webhook tidak bisa reach — halaman /checkout/selesai akan
# poll status sebagai fallback (atau pakai tunnel spt ngrok untuk uji webhook).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION="false"

# Tripay (closed payment, default channel QRIS). Webhook: <APP_URL>/api/payment/tripay
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_IS_PRODUCTION="false"

# Xendit (Invoice API, hosted). Webhook: <APP_URL>/api/payment/xendit
# XENDIT_CALLBACK_TOKEN dari Settings > Webhooks (Verification Token).
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=
